# Docker Compose DB service vars ONLY - EXAMPLE. Copy to db.env with real local values.
# db.env is gitignored; this example is tracked. NEVER put a real password here.
POSTGRES_DB=noon
POSTGRES_USER=noon
POSTGRES_PASSWORD=replace-with-your-local-db-password
# NOTE: POSTGRES_PASSWORD here must match DB_PASSWORD in .env (same value; rotate both together or Django's DB connect fails).
