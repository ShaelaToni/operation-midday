# Noon environment variables - EXAMPLE. Copy to .env and fill real LOCAL values.
# .env is gitignored; this .env.example is tracked. NEVER put real secrets here.

# --- Active in V1 ---
# NOTE: DB_PASSWORD here must match POSTGRES_PASSWORD in db.env (same value; rotate both together or Django's DB connect fails).
SECRET_KEY=replace-with-a-generated-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev
DB_NAME=noon
DB_USER=noon
DB_PASSWORD=replace-with-a-generated-local-password
DB_HOST=127.0.0.1
DB_PORT=5433
BASE_URL=http://localhost:8000

